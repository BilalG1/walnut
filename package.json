{
  "name": "walnut-cloud",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"bun run --filter @walnut/api dev\" \"bun run --filter @walnut/web dev\"",
    "build": "bun run --filter '*' build",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "db:generate": "bun run --filter @walnut/db generate",
    "db:push": "bun run --filter @walnut/db push",
    "db:migrate": "bun run --filter @walnut/db migrate",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "concurrently": "9.2.1",
    "oxlint": "1.66.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
