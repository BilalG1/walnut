# ─── Port prefix (the one knob) ───────────────────────────────────────────────
# One value controls every local port. Each service is <PORT_PREFIX><offset>:
#   web = <prefix>00 · api = <prefix>01 · postgres = <prefix>02
# Default 30 -> 3000 / 3001 / 3002. Must be two digits (11–99). Change this and the
# whole stack — docker, api, web, drizzle, tests — moves together. Run two fully
# isolated copies by giving each its own prefix (e.g. 30 and 41), no other edits.
PORT_PREFIX=30

# Neon API key — provisions a serverless Postgres per project.
# Get one at https://console.neon.tech (Account settings -> API keys).
NEON_API_KEY=

# Database provider for provisioning per-project databases.
#   "local" -> creates a database on the local docker Postgres (no Neon needed, used by tests)
#   "neon"  -> calls the real Neon API (requires NEON_API_KEY)
DB_PROVIDER=local

# ─── Storage (per-branch object store) ────────────────────────────────────────
# Blob provider for per-branch storage.
#   "local" -> MinIO on the local docker (S3 API on <prefix>03, console on <prefix>04). No
#              extra config needed — endpoint/credentials/bucket all derive from PORT_PREFIX.
#   "r2"    -> Cloudflare R2 in production (no egress fees). Requires the STORAGE_* vars below.
STORAGE_PROVIDER=local
# Required for r2 (ignored for local, which derives them):
# STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# STORAGE_BUCKET=walnut
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_REGION=auto

# ─── Optional overrides ───────────────────────────────────────────────────────
# Everything below is DERIVED from PORT_PREFIX by default. Uncomment to pin an
# explicit value — e.g. point DATABASE_URL at a remote/Neon metadata DB in prod.
#
# Platform metadata database (defaults to the local docker Postgres on <prefix>02).
# DATABASE_URL=postgres://walnut:walnut@localhost:3002/walnut
# Base URL the local provider uses when handing out per-project connection strings.
# LOCAL_PG_ADMIN_URL=postgres://walnut:walnut@localhost:3002/postgres
# API server port (defaults to <prefix>01).
# PORT=3001
# Comma-separated list of allowed CORS origins (defaults to the web app's URL, <prefix>00).
# CORS_ORIGIN=http://localhost:3000
# Walnut API base the dashboard talks to (defaults to <prefix>01).
# VITE_API_URL=http://localhost:3001

# ─── User authentication ──────────────────────────────────────────────────────
# AUTH_PROVIDER selects how the dashboard signs users in:
#   "local"    -> built-in, offline, passwordless provider. No signup, no network, no
#                 keys — the dashboard auto-signs-in as a single local user. The default
#                 when HEXCLAVE_PROJECT_ID is unset, so a fresh clone Just Works.
#   "hexclave" -> verify real Hexclave tokens (Google/GitHub OAuth). The default when
#                 HEXCLAVE_PROJECT_ID is set. Used by the hosted product.
# Leave unset to auto-pick (local unless a project id is configured). In production
# (NODE_ENV=production) the implicit fallback to passwordless auth is refused — set
# AUTH_PROVIDER=local explicitly to run the built-in auth in a prod build.
# AUTH_PROVIDER=local
#
# Hexclave project id — only needed for AUTH_PROVIDER=hexclave. The API verifies dashboard
# access tokens offline against Hexclave's JWKS; only the project id is needed to verify.
HEXCLAVE_PROJECT_ID=
# Hexclave API base URL (override only for self-hosted / staging).
HEXCLAVE_API_BASE_URL=https://api.hexclave.com

# --- Local dev login bypass (NEVER set these in production) ---
# Mounts POST /dev/auth/login, which trades an email for a real Hexclave session so you
# can sign in locally without the OAuth flow. Only takes effect when NODE_ENV != production.
AUTH_DEV_BYPASS=
# Hexclave secret server key (ssk_...). Required by the dev-login bypass to mint sessions.
# Leave this UNSET in production — its absence is the structural lock that disables the bypass.
HEXCLAVE_SECRET_SERVER_KEY=

# --- Error reporting (Sentry). All OPTIONAL — each is off unless its DSN is set, so dev
#     and tests never phone home. Configure them per deploy for production observability. ---
# API server error reporting (used by apps/api). Unset = disabled.
SENTRY_DSN=
# Fraction of transactions to trace (0–1). Default 0 = error reporting only, no tracing.
# SENTRY_TRACES_SAMPLE_RATE=0
# Release identifier attached to events (api + cli + web), e.g. a git SHA. Optional.
# SENTRY_RELEASE=
# CLI crash reporting (used by apps/cli). Separate from SENTRY_DSN so a server DSN never
# silently captures CLI crashes. Unset = disabled.
WALNUT_SENTRY_DSN=

# --- Frontend (Vite). Only VITE_*-prefixed vars are exposed to the browser. ---
# Dashboard error reporting (used by apps/web). A browser DSN is public by design. Unset = disabled.
VITE_SENTRY_DSN=
# Release identifier attached to browser events. Optional.
# VITE_SENTRY_RELEASE=
# Hexclave project id (required for OAuth + refresh).
VITE_HEXCLAVE_PROJECT_ID=
# Publishable client key (safe to ship to the client). OPTIONAL: if your project doesn't
# require one, leave it blank and the client sends the `__stack_public_client__` sentinel.
VITE_HEXCLAVE_PUBLISHABLE_CLIENT_KEY=
VITE_HEXCLAVE_API_BASE_URL=https://api.hexclave.com
# Show the dev-login form in the dashboard. On automatically in `vite dev`; set to 1 to
# force it on for a production-mode build (don't, except for local testing).
VITE_AUTH_DEV_BYPASS=
